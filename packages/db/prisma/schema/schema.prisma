generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "esm"
  runtime      = "bun"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  ACCOUNTANT
  OPERATIONS
  DRIVER
}

enum TruckStatus {
  AVAILABLE
  IN_TRANSIT
  MAINTENANCE
  RETIRED
}

enum TripStatus {
  PLANNED
  ACTIVE
  COMPLETED
  SETTLED
}

enum ExpenseType {
  FUEL
  MAINTENANCE
  DRIVER_COST
  TOLL
  INSURANCE
  PARKING
  PERMITS
  REPAIRS
  CLEANING
  MEALS
  EQUIPMENT
  MISC
}

enum PlanName {
  FOUNDATION
  CONTROL
  COMMAND
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum CrashSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CrashReportStatus {
  SUBMITTED
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum InspectionResult {
  PASS
  FAIL
  NEEDS_ATTENTION
}

enum Platform {
  IOS
  ANDROID
  WEB
}

// ─── Auth Models ─────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  name        String
  role        Role      @default(ADMIN)
  active      Boolean   @default(true)
  onboardedAt DateTime?
  businessId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sessions      Session[]
  driver        Driver?
  notifications Notification[]
  pushTokens    PushToken[]
  issues        Issue[]
  savedReports  SavedReport[]
  business      Business? @relation(fields: [businessId], references: [id])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Business {
  id                 String             @id @default(cuid())
  name               String
  location           String
  truckCount         Int                @default(0)
  employeeCount      Int                @default(0)
  phone              String?
  plan               PlanName?
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  planActivatedAt    DateTime?
  storageUsedBytes   BigInt             @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  users               User[]
  intermediatePayments IntermediatePayment[]
}

// ─── Core Operations ────────────────────────────────────

model Truck {
  id          String      @id @default(cuid())
  plateNumber String      @unique
  model       String
  year        Int?
  status      TruckStatus @default(AVAILABLE)
  acquiredAt  DateTime?
  disposedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  trips            Trip[]
  expenses         Expense[]
  crashReports     CrashReport[]
  issues           Issue[]
  inspections      InspectionReport[]
  serviceReminders ServiceReminder[]
}

model Driver {
  id        String   @id @default(cuid())
  userId    String   @unique
  licenseNo String   @unique
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  trips    Trip[]
  expenses Expense[]
  crashReports CrashReport[]
  issues   Issue[]
  inspections InspectionReport[]
}

model Trip {
  id          String     @id @default(cuid())
  origin      String
  destination String
  status      TripStatus @default(PLANNED)
  driverId    String
  truckId     String
  distance    Decimal?
  notes       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  driver   Driver    @relation(fields: [driverId], references: [id])
  truck    Truck     @relation(fields: [truckId], references: [id])
  expenses Expense[]
  revenue  Revenue?
  crashReports CrashReport[]
}

// ─── Financial Models ───────────────────────────────────

model Expense {
  id          String      @id @default(cuid())
  amount      Decimal
  type        ExpenseType
  description String?
  tripId      String?
  truckId     String?
  driverId    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  trip   Trip?   @relation(fields: [tripId], references: [id])
  truck  Truck?  @relation(fields: [truckId], references: [id])
  driver Driver? @relation(fields: [driverId], references: [id])
}

model Revenue {
  id        String   @id @default(cuid())
  amount    Decimal
  tripId    String   @unique
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id])
}

// ─── System Models ──────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  type      String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  Platform
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Driver Reports ─────────────────────────────────────

model CrashReport {
  id          String            @id @default(cuid())
  driverId    String
  truckId     String
  tripId      String?
  description String
  severity    CrashSeverity
  status      CrashReportStatus @default(SUBMITTED)
  location    String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  driver Driver       @relation(fields: [driverId], references: [id])
  truck  Truck        @relation(fields: [truckId], references: [id])
  trip   Trip?        @relation(fields: [tripId], references: [id])
  photos ReportPhoto[]
}

model ReportPhoto {
  id            String   @id @default(cuid())
  crashReportId String
  url           String
  s3Key         String
  sizeBytes     BigInt
  createdAt     DateTime @default(now())

  crashReport CrashReport @relation(fields: [crashReportId], references: [id], onDelete: Cascade)
}

// ─── Billing Models ─────────────────────────────────────

model IntermediatePayment {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  planName   PlanName
  amount     Decimal
  paid       Boolean  @default(false)
  processed  Boolean  @default(false)
  polarCheckoutId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id])
}

// ─── Issues ─────────────────────────────────────────────

model Issue {
  id          String        @id @default(cuid())
  title       String
  description String
  severity    IssueSeverity
  status      IssueStatus   @default(OPEN)
  truckId     String?
  driverId    String?
  reportedBy  String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  truck    Truck?  @relation(fields: [truckId], references: [id])
  driver   Driver? @relation(fields: [driverId], references: [id])
  reporter User    @relation(fields: [reportedBy], references: [id])
}

// ─── Inspections ────────────────────────────────────────

model InspectionReport {
  id          String           @id @default(cuid())
  truckId     String
  driverId    String
  tires       InspectionResult
  brakes      InspectionResult
  lights      InspectionResult
  fluids      InspectionResult
  body        InspectionResult
  overall     InspectionResult
  notes       String?
  mileage     Int?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  truck  Truck  @relation(fields: [truckId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])
}

// ─── Vehicle Maintenance ────────────────────────────────

model ServiceReminder {
  id          String    @id @default(cuid())
  truckId     String
  title       String
  description String?
  dueDate     DateTime
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  truck Truck @relation(fields: [truckId], references: [id])
}

// ─── Saved Reports ──────────────────────────────────────

model SavedReport {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  config    Json
  schedule  String?
  lastSentAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
