generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "esm"
  runtime      = "bun"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  ACCOUNTANT
  OPERATIONS
  DRIVER
}

enum TruckStatus {
  AVAILABLE
  IN_TRANSIT
  MAINTENANCE
  RETIRED
}

enum TripStatus {
  PLANNED
  ACTIVE
  COMPLETED
  SETTLED
}

enum ExpenseType {
  FUEL
  MAINTENANCE
  DRIVER_COST
  TOLL
  MISC
}

// ─── Auth Models ─────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(DRIVER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions      Session[]
  driver        Driver?
  notifications Notification[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Core Operations ────────────────────────────────────

model Truck {
  id          String      @id @default(cuid())
  plateNumber String      @unique
  model       String
  year        Int?
  status      TruckStatus @default(AVAILABLE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  trips    Trip[]
  expenses Expense[]
}

model Driver {
  id        String   @id @default(cuid())
  userId    String   @unique
  licenseNo String   @unique
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  trips    Trip[]
  expenses Expense[]
}

model Trip {
  id          String     @id @default(cuid())
  origin      String
  destination String
  status      TripStatus @default(PLANNED)
  driverId    String
  truckId     String
  distance    Decimal?
  notes       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  driver   Driver    @relation(fields: [driverId], references: [id])
  truck    Truck     @relation(fields: [truckId], references: [id])
  expenses Expense[]
  revenue  Revenue?
}

// ─── Financial Models ───────────────────────────────────

model Expense {
  id          String      @id @default(cuid())
  amount      Decimal
  type        ExpenseType
  description String?
  tripId      String?
  truckId     String?
  driverId    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  trip   Trip?   @relation(fields: [tripId], references: [id])
  truck  Truck?  @relation(fields: [truckId], references: [id])
  driver Driver? @relation(fields: [driverId], references: [id])
}

model Revenue {
  id        String   @id @default(cuid())
  amount    Decimal
  tripId    String   @unique
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id])
}

// ─── System Models ──────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  type      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
